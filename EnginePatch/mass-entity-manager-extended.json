              "add": [
                "",
                "void FMassEntityManager::DestroyEntity(FMassEntityHandle Entity, bool bSignalObservers)",
                "{",
                "\tCHECK_SYNC_API();",
                "\tCheckIfEntityIsActive(Entity);",
                "\tFMassArchetypeData* Archetype = GetEntityStorageInterface().GetArchetype(Entity.Index);",
                "\tif (bSignalObservers && Archetype)",
                "\t{",
                "\t\tObserverManager.OnPreEntityDestroyed(Archetype->GetCompositionDescriptor(), Entity);",
                "\t}",
                "\tif (Archetype)",
                "\t{",
                "\t\tArchetype->RemoveEntity(Entity);",
                "\t}",
                "\tInternalReleaseEntity(Entity);",
                "}",
                "",
                "void FMassEntityManager::BuildEntity(FMassEntityHandle Entity, const FMassArchetypeHandle& ArchetypeHandle, const FMassArchetypeSharedFragmentValues& SharedFragmentValues, bool bSignalObservers, int32 ChunkIndex)",
                "{",
                "\tCHECK_SYNC_API();",
                "\tcheckf(!IsEntityBuilt(Entity), TEXT(\"Expecting an entity that is not already built\"));",
                "\tcheck(ArchetypeHandle.IsValid());",
                "\tGetEntityStorageInterface().SetArchetypeFromShared(Entity.Index, ArchetypeHandle.DataPtr);",
                "\tArchetypeHandle.DataPtr->AddEntityToChunk(Entity, SharedFragmentValues, ChunkIndex);",
                "\tif (bSignalObservers)",
                "\t{",
                "\t\tObserverManager.OnPostEntityCreated(Entity, ArchetypeHandle.DataPtr->GetCompositionDescriptor());",
                "\t}",
                "}",
                "",
                "void FMassEntityManager::DestroyAllEntities()",
                "{",
                "\tconst TArray<FMassEntityHandle> Entities = GetAllEntities();",
                "\tfor (const FMassEntityHandle& Entity : Entities)",
                "\t{",
                "\t\tDestroyEntity(Entity, false);",
                "\t}",
                "}",
                "",
                "void FMassEntityManager::RestoreEntitySerialNumber(FMassEntityHandle& Entity, int32 SerialNumber)",
                "{",
                "\tCheckIfEntityIsValid(Entity);",
                "\tcheckf(!IsEntityBuilt(Entity), TEXT(\"Entity has already been built (ID: %d, SN: %d)\"), Entity.Index, Entity.SerialNumber);",
                "\tGetEntityStorageInterface().RestoreEntitySerialNumber(Entity, SerialNumber);",
                "}",
                "",
                "void FMassEntityManager::GetEntityData(const FMassEntityHandle& Entity, TArray<FInstancedStruct>& OutFragmentInstanceList) const",
                "{",
                "\tcheck(IsEntityBuilt(Entity));",
                "\tconst FMassArchetypeData& ArchetypeData = *GetEntityStorageInterface().GetArchetype(Entity.Index);",
                "\tOutFragmentInstanceList.Reset();",
                "\tfor (const FMassArchetypeFragmentConfig& FragConfig : ArchetypeData.GetFragmentConfigs())",
                "\t{",
                "\t\tif (FragConfig.FragmentType)",
                "\t\t{",
                "\t\t\tconst void* SrcMem = ArchetypeData.GetFragmentDataForEntityChecked(FragConfig.FragmentType, Entity);",
                "\t\t\tOutFragmentInstanceList.AddDefaulted_GetRef().InitializeAs(FragConfig.FragmentType, static_cast<const uint8*>(SrcMem));",
                "\t\t}",
                "\t}",
                "}",
                "",
                "TMap<uint32, FSharedStruct> FMassEntityManager::GetSharedFragmentValuesMap() const",
                "{",
                "\tTMap<uint32, FSharedStruct> Result;",
                "\tfor (const TPair<uint32, int32>& Pair : SharedFragmentsContainer.GetHashToInstanceIndexMap())",
                "\t{",
                "\t\tResult.Add(Pair.Key, SharedFragmentsContainer[Pair.Value]);",
                "\t}",
                "\treturn Result;",
                "}",
                "",
                "void FMassEntityManager::SetSharedFragments(const TMap<uint32, FInstancedStruct>& InSharedFragmentsMap)",
                "{",
                "\tfor (const TPair<uint32, int32>& Pair : SharedFragmentsContainer.GetHashToInstanceIndexMap())",
                "\t{",
                "\t\tFSharedStruct& Instance = SharedFragmentsContainer[Pair.Value];",
                "\t\tconst UScriptStruct* Type = Instance.GetScriptStruct();",
                "\t\tcheck(Type != nullptr);",
                "\t\tif (const FInstancedStruct* NewData = InSharedFragmentsMap.Find(Pair.Key))",
                "\t\t{",
                "\t\t\tcheck(Type == NewData->GetScriptStruct());",
                "\t\t\tType->CopyScriptStruct(Instance.GetMemory(), NewData->GetMemory());",
                "\t\t}",
                "\t\telse",
                "\t\t{",
                "\t\t\tif (const FInstancedStruct* DefaultData = DefaultSharedFragments.Find(Type))",
                "\t\t\t{",
                "\t\t\t\tType->CopyScriptStruct(Instance.GetMemory(), DefaultData->GetMemory());",
                "\t\t\t}",
                "\t\t}",
                "\t}",
                "}",
                "",
                "void FMassEntityManager::ResetAllSharedFragments()",
                "{",
                "\tfor (FSharedStruct& Instance : SharedFragmentsContainer.GetAllInstances())",
                "\t{",
                "\t\tif (const UScriptStruct* Type = Instance.GetScriptStruct())",
                "\t\t{",
                "\t\t\tif (const FInstancedStruct* DefaultData = DefaultSharedFragments.Find(Type))",
                "\t\t\t{",
                "\t\t\t\tType->CopyScriptStruct(Instance.GetMemory(), DefaultData->GetMemory());",
                "\t\t\t}",
                "\t\t}",
                "\t}",
                "}",
                "",
                "uint32 FMassEntityManager::GetSharedFragmentHashChecked(const FSharedStruct& SharedFragment) const",
                "{",
                "\tconst TArrayView<const FSharedStruct> Instances = SharedFragmentsContainer.GetAllInstances();",
                "\tconst int32 Index = Instances.IndexOfByKey(SharedFragment);",
                "\tcheck(Index != INDEX_NONE);",
                "\tconst uint32* Hash = SharedFragmentsContainer.GetHashToInstanceIndexMap().FindKey(Index);",
                "\tcheck(Hash != nullptr);",
                "\treturn *Hash;",
                "}",
                "",
                "uint32 FMassEntityManager::GetConstSharedFragmentHashChecked(const FConstSharedStruct& ConstSharedFragment) const",
                "{",
                "\tconst TArrayView<const FConstSharedStruct> Instances = ConstSharedFragmentsContainer.GetAllInstances();",
                "\tconst int32 Index = Instances.IndexOfByKey(ConstSharedFragment);",
                "\tcheck(Index != INDEX_NONE);",
                "\tconst uint32* Hash = ConstSharedFragmentsContainer.GetHashToInstanceIndexMap().FindKey(Index);",
                "\tcheck(Hash != nullptr);",
                "\treturn *Hash;",
                "}",
                "",
                "const FSharedStruct& FMassEntityManager::GetSharedFragmentByHashChecked(uint32 Hash) const",
                "{",
                "\tconst int32 Index = SharedFragmentsContainer.GetHashToInstanceIndexMap().FindChecked(Hash);",
                "\treturn SharedFragmentsContainer[Index];",
                "}",
                "",
                "const FConstSharedStruct& FMassEntityManager::GetConstSharedFragmentByHashChecked(uint32 Hash) const",
                "{",
                "\tconst int32 Index = ConstSharedFragmentsContainer.GetHashToInstanceIndexMap().FindChecked(Hash);",
                "\treturn ConstSharedFragmentsContainer[Index];",
                "}",
                "",
                "int32 FMassEntityManager::GetArchetypeChunkCount(const FMassArchetypeHandle& ArchetypeHandle) const",
                "{",
                "\tcheck(ArchetypeHandle.IsValid());",
                "\treturn FMassArchetypeHelper::ArchetypeDataFromHandleChecked(ArchetypeHandle).GetChunkCount();",
                "}",
                "",
                "const FMassArchetypeSharedFragmentValues& FMassEntityManager::GetArchetypeSharedFragmentValues(const FMassArchetypeHandle& ArchetypeHandle, int32 ChunkIndex) const",
                "{",
                "\tcheck(ArchetypeHandle.IsValid());",
                "\treturn FMassArchetypeHelper::ArchetypeDataFromHandleChecked(ArchetypeHandle).GetChunkSharedFragmentValues(ChunkIndex);",
                "}",
                "",
                "void FMassEntityManager::GetArchetypeInternalIndexForEntity(const FMassEntityHandle& Entity, const FMassArchetypeHandle& ArchetypeHandle, int32& OutAbsoluteIndex, int32& OutChunkIndex) const",
                "{",
                "\tcheck(ArchetypeHandle.IsValid());",
                "\tconst FMassArchetypeData& ArchetypeData = FMassArchetypeHelper::ArchetypeDataFromHandleChecked(ArchetypeHandle);",
                "\tconst int32* InternalIndex = ArchetypeData.GetInternalIndexForEntity(Entity.Index);",
                "\tcheck(InternalIndex != nullptr);",
                "\tOutAbsoluteIndex = *InternalIndex;",
                "\tOutChunkIndex = OutAbsoluteIndex / ArchetypeData.GetNumEntitiesPerChunk();",
                "}",
                "",
                "void FMassEntityManager::EnsureArchetypeChunkSharedFragmentValues(const FMassArchetypeHandle& ArchetypeHandle, int32 ChunkIndex, const FMassArchetypeSharedFragmentValues& SharedFragmentValues)",
                "{",
                "\tcheck(ArchetypeHandle.IsValid());",
                "\tArchetypeHandle.DataPtr->EnsureChunkSharedFragmentValues(ChunkIndex, SharedFragmentValues);",
                "}",
                "",
                "uint32 FMassEntityManager::GetStructCrc32(const FConstStructView& StructView, const uint32 CRC /*= 0*/)",
                "{",
                "\treturn GetStructCrc32(*StructView.GetScriptStruct(), StructView.GetMemory(), CRC);",
                "}",
                "",
                "uint32 FMassEntityManager::GetStructCrc32(const UScriptStruct& ScriptStruct, const uint8* StructMemory, const uint32 CRC /*= 0*/)",
                "{",
                "\tconst FString StructPathName = ScriptStruct.GetPathName();",
                "",
                "\t// MurmurFinalize32",
                "\tuint32 StructHash = GetTypeHash(StructPathName);",
                "\tStructHash ^= StructHash >> 16;",
                "\tStructHash *= 0x85ebca6b;",
                "\tStructHash ^= StructHash >> 13;",
                "\tStructHash *= 0xc2b2ae35;",
                "\tStructHash ^= StructHash >> 16;",
                "",
                "\tFArchiveCrc32 Ar(HashCombine(CRC, StructHash));",
                "\tUScriptStruct& NonConstScriptStruct = const_cast<UScriptStruct&>(ScriptStruct);",
                "\tNonConstScriptStruct.SerializeItem(Ar, const_cast<uint8*>(StructMemory), nullptr);",
                "",
                "\tconst uint32 Hash = Ar.GetCrc();",
                "\treturn Hash;",
                "}"
              ]
            }
          ]
        }
      ]
