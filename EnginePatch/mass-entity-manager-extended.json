              "id": "add-entity-to-chunk-impl",
              "line": 386,
              "remove": [],
              "add": [
                "",
                "void FMassArchetypeData::AddEntityToChunk(FMassEntityHandle Entity, const FMassArchetypeSharedFragmentValues& SharedFragmentValues, int32 ChunkIndex)",
                "{",
                "\t++ArchetypeVersion;",
                "",
                "\tint32 IndexWithinChunk = 0;",
                "\tint32 AbsoluteIndex = 0;",
                "\tFMassArchetypeChunk* DestinationChunk = nullptr;",
                "",
                "\tif (ChunkIndex != INDEX_NONE && ChunkIndex < Chunks.Num())",
                "\t{",
                "\t\tDestinationChunk = &Chunks[ChunkIndex];",
                "\t\tif (DestinationChunk->GetNumInstances() == 0)",
                "\t\t{",
                "\t\t\tDestinationChunk->Recycle(ChunkFragmentsTemplate, SharedFragmentValues);",
                "\t\t}",
                "\t\tIndexWithinChunk = DestinationChunk->GetNumInstances();",
                "\t\tAbsoluteIndex = ChunkIndex * NumEntitiesPerChunk + IndexWithinChunk;",
                "\t}",
                "\telse",
                "\t{",
                "\t\tDestinationChunk = &GetOrAddChunk(SharedFragmentValues, AbsoluteIndex, IndexWithinChunk);",
                "\t}",
                "",
                "\tDestinationChunk->AddInstance();",
                "\tEntityMap.Add(Entity.Index, AbsoluteIndex);",
                "\tDestinationChunk->GetEntityArrayElementRef(EntityListOffsetWithinChunk, IndexWithinChunk) = Entity;",
                "",
                "\t// Initialize fragments",
                "\tfor (const FMassArchetypeFragmentConfig& FragmentConfig : FragmentConfigs)",
                "\t{",
                "\t\tvoid* FragmentPtr = FragmentConfig.GetFragmentData(DestinationChunk->GetRawMemory(), IndexWithinChunk);",
                "\t\tFragmentConfig.FragmentType->InitializeStruct(FragmentPtr);",
                "\t}",
                "}"
              ]
            }
          ]
