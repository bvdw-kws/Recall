            {
              "id": "add-entity-to-chunk-impl",
              "line": 385,
              "remove": [],
              "add": [
                "",
                "void FMassArchetypeData::AddEntityToChunk(FMassEntityHandle Entity, const FMassArchetypeSharedFragmentValues& SharedFragmentValues, int32 ChunkIndex)",
                "{",
                "\tif (ChunkIndex == INDEX_NONE)",
                "\t{",
                "\t\tAddEntity(Entity, SharedFragmentValues);",
                "\t\treturn;",
                "\t}",
                "",
                "\t++ArchetypeVersion;",
                "",
                "\tbool bNewChunk = false;",
                "\twhile (!Chunks.IsValidIndex(ChunkIndex))",
                "\t{",
                "\t\tChunks.Emplace(GetChunkAllocSize(), ChunkFragmentsTemplate, SharedFragmentValues);",
                "\t\tbNewChunk = true;",
                "\t}",
                "",
                "\tFMassArchetypeChunk& DestinationChunk = Chunks[ChunkIndex];",
                "\tif (!bNewChunk && DestinationChunk.GetNumInstances() == 0)",
                "\t{",
                "\t\tDestinationChunk.Recycle(ChunkFragmentsTemplate, SharedFragmentValues);",
                "\t}",
                "",
                "\tconst int32 IndexWithinChunk = DestinationChunk.GetNumInstances();",
                "\tconst int32 AbsoluteIndex = ChunkIndex * NumEntitiesPerChunk + IndexWithinChunk;",
                "",
                "\tDestinationChunk.AddInstance();",
                "\tEntityMap.Add(Entity.Index, AbsoluteIndex);",
                "\tDestinationChunk.GetEntityArrayElementRef(EntityListOffsetWithinChunk, IndexWithinChunk) = Entity;",
                "",
                "\tfor (const FMassArchetypeFragmentConfig& FragmentConfig : FragmentConfigs)",
                "\t{",
                "\t\tvoid* FragmentPtr = FragmentConfig.GetFragmentData(DestinationChunk.GetRawMemory(), IndexWithinChunk);",
                "\t\tFragmentConfig.FragmentType->InitializeStruct(FragmentPtr);",
                "\t}",
                "}",
                "",
                "void FMassArchetypeData::EnsureChunkSharedFragmentValues(int32 ChunkIndex, const FMassArchetypeSharedFragmentValues& SharedFragmentValues)",
                "{",
                "\t++ArchetypeVersion;",
                "",
                "\tbool bNewChunk = false;",
                "\twhile (!Chunks.IsValidIndex(ChunkIndex))",
                "\t{",
                "\t\tChunks.Emplace(GetChunkAllocSize(), ChunkFragmentsTemplate, SharedFragmentValues);",
                "\t\tbNewChunk = true;",
                "\t}",
                "",
                "\tFMassArchetypeChunk& DestinationChunk = Chunks[ChunkIndex];",
                "\tif (!bNewChunk && DestinationChunk.GetNumInstances() == 0 && !DestinationChunk.GetSharedFragmentValues().IsEquivalent(SharedFragmentValues))",
                "\t{",
                "\t\tDestinationChunk.Recycle(ChunkFragmentsTemplate, SharedFragmentValues);",
                "\t}",
                "}"
              ]
            }
          ]
        },
