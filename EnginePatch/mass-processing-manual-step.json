          "operations": [
            {
              "id": "add-phase-execute-step-impl",
              "line": 65,
              "remove": [],
              "add": [
                "",
                "void FMassProcessingPhase::ExecuteStep(float DeltaTime)",
                "{",
                "\tSCOPE_CYCLE_COUNTER(STAT_Mass_PhaseTick);",
                "\tSCOPE_CYCLE_COUNTER(STAT_Mass_Total);",
                "",
                "\tcheckf(PhaseManager, TEXT(\"Manager is null which is not a supported case. Either this FMassProcessingPhase has not been initialized properly or it's been left dangling after the FMassProcessingPhase owner got destroyed.\"));",
                "",
                "\tTRACE_CPUPROFILER_EVENT_SCOPE_TEXT(*FString::Printf(TEXT(\"FMassProcessingPhase::ExecuteStep %s\"), *UEnum::GetValueAsString(Phase)));",
                "",
                "\tPhaseManager->OnPhaseStart(*this);",
                "\t{",
                "\t\tLLM_SCOPE_BYNAME(TEXT(\"Mass/PhaseStartDelegate\"));",
                "\t\tOnPhaseStart.Broadcast(DeltaTime);",
                "\t}",
                "",
                "\tcheck(PhaseProcessor);",
                "",
                "\tFMassEntityManager& EntityManager = PhaseManager->GetEntityManagerRef();",
                "",
                "\tbIsDuringMassProcessing = true;",
                "",
                "\tif (bRunInParallelMode && PhaseManager->IsPaused() == false)",
                "\t{",
                "\t\tbool bWorkRequested = false;",
                "\t\tif (PhaseProcessor->IsEmpty() == false)",
                "\t\t{",
                "\t\t\tObserversLockPtr = EntityManager.GetOrMakeObserversLock().ToSharedPtr();",
                "\t\t\tFMassProcessingContext Context(EntityManager, DeltaTime);",
                "",
                "\t\t\tconst FGraphEventRef PipelineCompletionEvent = UE::Mass::Executor::TriggerParallelTasks(*PhaseProcessor, MoveTemp(Context), [this, DeltaTime]()",
                "\t\t\t\t{",
                "\t\t\t\t\tOnParallelExecutionDone(DeltaTime);",
                "\t\t\t\t}",
                "\t\t\t\t, FTaskGraphInterface::Get().GetCurrentThreadIfKnown());",
                "",
                "\t\t\tif (PipelineCompletionEvent.IsValid())",
                "\t\t\t{",
                "\t\t\t\tPipelineCompletionEvent->Wait(FTaskGraphInterface::Get().GetCurrentThreadIfKnown());",
                "\t\t\t\tbWorkRequested = true;",
                "\t\t\t}",
                "\t\t}",
                "\t\tif (bWorkRequested == false)",
                "\t\t{",
                "\t\t\tObserversLockPtr = nullptr;",
                "\t\t\tOnParallelExecutionDone(DeltaTime);",
                "\t\t}",
                "\t}",
                "\telse",
                "\t{",
                "\t\tif (PhaseManager->IsPaused() == false)",
                "\t\t{",
                "\t\t\tObserversLockPtr = EntityManager.GetOrMakeObserversLock().ToSharedPtr();",
                "\t\t\tFMassProcessingContext Context(EntityManager, DeltaTime);",
                "\t\t\tUE::Mass::Executor::Run(*PhaseProcessor, Context);",
                "\t\t\tObserversLockPtr = nullptr;",
                "\t\t}",
                "",
                "\t\tbIsDuringMassProcessing = false;",
                "\t\t{",
                "\t\t\tLLM_SCOPE_BYNAME(TEXT(\"Mass/PhaseEndDelegate\"));",
                "\t\t\tOnPhaseEnd.Broadcast(DeltaTime);",
                "\t\t}",
                "\t\tPhaseManager->OnPhaseEnd(*this);",
                "\t}",
                "}"
              ]
            },
            {
              "id": "add-manager-step-impl",
              "line": 515,
              "remove": [],
              "add": [
                "",
                "void FMassProcessingPhaseManager::Step(EMassProcessingPhase Phase, float DeltaTime)",
                "{",
                "\tUE_VLOG_UELOG(Owner.Get(), LogMass, Log, TEXT(\"FMassProcessingPhaseManager::Step <%s>\"), *UEnum::GetDisplayValueAsText(Phase).ToString());",
                "",
                "\tconst int32 PhaseIndex = static_cast<int32>(Phase);",
                "",
                "\tif (ProcessingPhases[PhaseIndex].PhaseProcessor)",
                "\t{",
                "\t\tProcessingPhases[PhaseIndex].ExecuteStep(DeltaTime);",
                "\t}",
                "}",
                "",
                "void FMassProcessingPhaseManager::DisableTickFunctions()",
                "{",
                "\tfor (FMassProcessingPhase& Phase : ProcessingPhases)",
                "\t{",
                "\t\tPhase.UnRegisterTickFunction();",
                "\t\tPhase.SetTickFunctionEnable(false);",
                "\t}",
                "}"
              ]
            }
          ]
        }
      ]
    }
  ]
}
