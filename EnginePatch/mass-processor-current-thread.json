{
  "patchId": "mass-processor-current-thread",
  "description": "Use GetCurrentThreadIfKnown instead of forcing GameThread+HighTaskPriority for game-thread processor tasks (Recall)",
  "plugin": "Recall",
  "versions": [
    {
      "engineVersions": ["5.8"],
      "files": [
        {
          "file": "Runtime/MassEntity/Private/MassProcessor.cpp",
          "operations": [
            {
              "id": "use-current-thread",
              "line": 125,
              "remove": [
                "\t\treturn ENamedThreads::SetTaskPriority(ENamedThreads::GameThread, ENamedThreads::HighTaskPriority);"
              ],
              "add": [
                "\t\treturn FTaskGraphInterface::Get().GetCurrentThreadIfKnown();"
              ]
            }
          ]
        }
      ]
    }
  ]
}
