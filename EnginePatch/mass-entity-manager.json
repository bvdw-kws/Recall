              "add": [
                "",
                "int32 FMassEntityManager::GetSerialNumberGenerator() const",
                "{",
                "\treturn GetEntityStorageInterface().GetSerialNumberGenerator();",
                "}",
                "",
                "void FMassEntityManager::SetSerialNumberGenerator(int32 InValue)",
                "{",
                "\tGetEntityStorageInterface().SetSerialNumberGenerator(InValue);",
                "}",
                "",
                "TArray<FMassEntityHandle> FMassEntityManager::GetAllEntities() const",
                "{",
                "\tTArray<FMassEntityHandle> Result;",
                "\tconst int32 StorageNum = GetEntityStorageInterface().Num();",
                "\tResult.Reserve(StorageNum);",
                "\tfor (int32 Idx = NumReservedEntities; Idx < StorageNum; ++Idx)",
                "\t{",
                "\t\tif (GetEntityStorageInterface().IsValid(Idx))",
                "\t\t{",
                "\t\t\tFMassEntityHandle Handle;",
                "\t\t\tHandle.Index = Idx;",
                "\t\t\tHandle.SerialNumber = GetEntityStorageInterface().GetSerialNumber(Idx);",
                "\t\t\tResult.Add(Handle);",
                "\t\t}",
                "\t}",
                "\treturn Result;",
                "}"
              ]
            }
          ]
        }
